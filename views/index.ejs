  <!DOCTYPE html>
  <html lang="en">
    <head>
      <meta charset="UTF-8" />
      <meta name="viewport" content="width=device-width, initial-scale=1.0" />
      <title>Dark Themed Page</title>
      <link rel="stylesheet" href="styles/index.css">
      <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;700&display=swap" rel="stylesheet">

    </head>
    <body>
      <div class="container">
        <h1>Welcome to <span class="highlight">ArticleChat</span></h1>
        <p>“Post ideas. Start discussions. Let your articles talk — because every
        article deserves a voice.”</p>
        <div class="buttons">
          <form action="/get_started" method="get">
            <input type="submit" value="Get Started" />
          </form>
        </div>
      </div>
    </body>
  </html>


