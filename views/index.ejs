<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="styles/style.css" />
    <title>Article Chat</title>
  </head>
  <body>
    <div class="container">
      <h1 class="heading">Welcome to Article Chat</h1>
      <p class="info">Don't just write articles, share them across the globe.</p>
      <hr>
      <div class="form-box">
      <form action="/signin" method="GET">
        <input class="btn-signin" type="submit" value="Sign In" />
      </form>
      <form action="/login" method="GET">
        <input class="btn-login" type="submit" value="Log In" />
      </form>
    </div>
    </div>
  </body>
</html>
