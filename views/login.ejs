<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/styles/style.css" />
    <title>Log In</title>
  </head>
  <body class="">
    <main class="">
      <form action="/login" method="post">
        <h1 class="">Log In</h1>

        <div class="">
          <input
            type="text"
            class=""
            name="username"
            placeholder="name@example.com"
          />
          <label for="username">Username</label>
        </div>
        <% if (locals.message) { %>
            <p><%= message %></p>
        <% } %>
        <div class="">
          <input
            type="password"
            class=""
            name="password"
            placeholder="Password"
          />
          <label for="password">Password</label>
        </div>
        <button
          class=""
          type="submit"
        >
          Sign in
        </button>
        <p class="">© 2025</p>
      </form>
    </main>
  </body>
</html>
